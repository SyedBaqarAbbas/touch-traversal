flowchart TB
    accTitle: Touch Traversal system architecture
    accDescr: Fictional sample notes build four checked-in static artifacts. Explicitly selected personal notes can instead cross authenticated loopback into a temporary Python companion and return as an in-memory session. The browser validates either bundle, renders one Graphology model, and accepts mouse, keyboard, or optional local hand input. An explicit local compositor can create a downloadable silent recording.

    subgraph SOURCE["Local source"]
        direction LR
        NOTES["Fictional sample notes"]
        PERSONAL["Explicit personal file/folder choice"]
        CONFIG["Validated pipeline config"]
    end

    subgraph BUILD["Local build · Python 3.11"]
        direction LR
        PIPELINE["Batch graph pipeline"]
        COMPANION["Authenticated 127.0.0.1 companion\ntemporary per-job workspace"]
        STATICCONTRACT["Cross-artifact validation\nchecked-in sample output"]
        SESSIONCONTRACT["Cross-artifact validation\nin-memory personal return"]
    end

    subgraph STATIC["Checked-in static boundary"]
        direction LR
        GRAPH["graph.json\nnodes · typed edges · evidence"]
        LAYOUTS["layouts.json\nsemantic · clusters · temporal · force"]
        MANIFEST["manifest.json\ncounts · model · config hash"]
        REPORT["pipeline-report.json\nstatistics · warnings"]
    end

    subgraph BROWSER["Next.js browser application"]
        direction LR
        PREVIEW["Private metadata preview\nsecond send confirmation"]
        LOAD["Static fetch or memory session"]
        VALIDATE["Strict Zod bundle validation"]
        MODEL["Graphology model"]
        SCENE["React Three Fiber scene"]
        WEBGL["Three.js / WebGL renderer"]
    end

    subgraph MEDIA["Optional browser-local media"]
        direction LR
        INPUT["Mouse · keyboard\nlocal hand worker"]
        CAMERA["Explicit silent camera"]
        COMPOSITOR["Bounded graph + webcam compositor"]
        RECORDING["In-memory recording\nexplicit download or discard"]
    end

    NOTES --> PIPELINE
    PERSONAL --> PREVIEW --> COMPANION
    CONFIG --> PIPELINE
    CONFIG --> COMPANION
    PIPELINE --> STATICCONTRACT
    COMPANION --> SESSIONCONTRACT
    STATICCONTRACT --> GRAPH
    STATICCONTRACT --> LAYOUTS
    STATICCONTRACT --> MANIFEST
    STATICCONTRACT --> REPORT
    GRAPH --> LOAD
    LAYOUTS --> LOAD
    MANIFEST --> LOAD
    REPORT --> LOAD
    SESSIONCONTRACT -. "personal bundle / memory only" .-> LOAD
    LOAD --> VALIDATE
    VALIDATE --> MODEL
    MODEL --> SCENE
    INPUT --> SCENE
    CAMERA --> INPUT
    CAMERA --> COMPOSITOR
    SCENE --> COMPOSITOR --> RECORDING
    SCENE --> WEBGL

    classDef source fill:#f5f0e8,stroke:#765b36,color:#111111;
    classDef process fill:#f4f4f4,stroke:#555555,color:#111111;
    classDef artifact fill:#e8eef5,stroke:#385570,color:#111111;
    classDef output fill:#e7f1e8,stroke:#38633d,color:#111111;
    class NOTES,PERSONAL,CONFIG,CAMERA source;
    class PIPELINE,COMPANION,STATICCONTRACT,SESSIONCONTRACT,PREVIEW,LOAD,VALIDATE,MODEL,SCENE,INPUT,COMPOSITOR process;
    class GRAPH,LAYOUTS,MANIFEST,REPORT artifact;
    class WEBGL,RECORDING output;
